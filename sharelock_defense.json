{
  "template_name": "sharelock_threshold_defense",
  "target_protocol": "mcp",
  "version": "1.0",
  "author": "Applied_AI_Engineer",
  "threat_model": "ShareLock (Multi-Tool Payload Distribution)",
  "rules": [
    {
      "id": "sl_001",
      "type": "regex_filter",
      "direction": "outgoing",
      "description": "Drops JSON-RPC responses containing fragmented payload indicators (e.g., base64 fragments across multiple tool outputs)",
      "pattern": "(\"output\":\\s*\"[A-Za-z0-9+/=]{10,}\"\\s*,\\s*){3,}",
      "action": "drop_and_alert"
    },
    {
      "id": "sl_002",
      "type": "payload_size_limit",
      "direction": "incoming",
      "description": "Threshold limits per tool invocation to prevent large context stuffing",
      "max_bytes": 8192,
      "action": "reject"
    }
  ]
}
